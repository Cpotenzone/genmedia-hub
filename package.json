    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "firebase": "^10.12.2",
    "@firebase/auth": "^1.7.4",
    "lucide-react": "^0.395.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.1",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
