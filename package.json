{
  "name": "genmedia-hub",
  "version": "1.0.0",
  "private": true,
  "description": "GenMedia Hub — Unified interface for generative media MCP servers",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
